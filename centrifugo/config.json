{
  "client": {
    "token": {
      "hmac_secret_key": "centrifugo-token-secret"
    },
    "allowed_origins": ["http://localhost", "http://localhost:80"]
  },
  "channel": {
    "namespaces": [
      {
        "name": "match",
        "presence": true,
        "history_size": 50,
        "history_ttl": "300s",
        "force_recovery": true
      }
    ]
  },
  "http_api": {
    "key": "centrifugo-api-key"
  },
  "proxy": {
    "connect": {
      "enabled": true,
      "endpoint": "http://backend:3000/centrifugo/connect",
      "timeout": "5s"
    },
    "subscribe": {
      "enabled": true,
      "endpoint": "http://backend:3000/centrifugo/subscribe",
      "timeout": "5s"
    },
    "rpc": {
      "enabled": true,
      "endpoint": "http://backend:3000/centrifugo/rpc",
      "timeout": "10s"
    }
  },
  "broker": {
    "type": "redis",
    "redis": {
      "address": "redis://redis:6379"
    }
  },
  "presence_manager": {
    "type": "redis",
    "redis": {
      "address": "redis://redis:6379"
    }
  },
  "log_level": "info",
  "admin": {
    "enabled": true,
    "password": "admin",
    "secret": "admin-secret"
  }
}
