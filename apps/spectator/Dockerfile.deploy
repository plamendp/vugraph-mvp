# Production build — run scripts/prepare-build.sh spectator first
# Build: docker build -f apps/spectator/Dockerfile.deploy apps/spectator/

FROM node:22-alpine AS build
WORKDIR /app/apps/spectator
COPY package*.json ./
RUN npm ci
COPY tsconfig.json vite.config.ts ./
COPY src/ src/
# Shared code copied by prepare-build.sh
COPY _shared/ui/ /app/packages/ui/
COPY _shared/types/ /app/packages/types/
RUN npx vite build

FROM nginx:alpine
COPY --from=build /app/apps/spectator/dist /usr/share/nginx/html
EXPOSE 80
