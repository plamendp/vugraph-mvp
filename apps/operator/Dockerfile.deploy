# Production build — run scripts/prepare-build.sh operator first
# Build: docker build -f apps/operator/Dockerfile.deploy apps/operator/

FROM node:22-alpine AS build
WORKDIR /app/apps/operator
COPY package*.json ./
RUN npm ci
COPY tsconfig.json vite.config.ts ./
COPY src/ src/
# Shared code copied by prepare-build.sh
COPY _shared/ /app/packages/ui/
RUN npx vite build

FROM nginx:alpine
COPY --from=build /app/apps/operator/dist /usr/share/nginx/html
EXPOSE 80
