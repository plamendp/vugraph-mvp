{
  "client": {
    "proxy": {
      "connect": {
        "enabled": true,
        "endpoint": "http://backend:3000/centrifugo/connect",
        "timeout": "5s"
      },
      "subscribe": {
        "enabled": true,
        "endpoint": "http://backend:3000/centrifugo/subscribe",
        "timeout": "5s"
      },
      "rpc": {
        "enabled": true,
        "endpoint": "http://backend:3000/centrifugo/rpc",
        "timeout": "10s"
      }
    },
    "token": {
      "hmac_secret_key": ""
    },
    "allowed_origins": ["http://localhost", "http://localhost:80"],
    "subscribe_allowed": true
  },
  "channel": {
    "namespaces": [
      {
        "name": "match",
        "presence": true,
        "history_size": 50,
        "history_ttl": "300s",
        "force_recovery": true,
        "subscribe_proxy_required": false
      },
      {
        "name": "notifications",
        "history_size": 10,
        "history_ttl": "60s",
        "force_recovery": true,
        "subscribe_proxy_required": false
      }
    ]
  },
  "http_api": {
    "key": ""
  },
  "broker": {
    "type": "redis",
    "redis": {
      "dsn": "redis://redis:6379"
    }
  },
  "presence_manager": {
    "type": "redis",
    "redis": {
      "address": "redis://redis:6379"
    }
  },
  "log_level": "debug",
  "admin": {
    "enabled": true,
    "password": "",
    "secret": ""
  }
}
