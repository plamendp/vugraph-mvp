# Vugraph MVP — Local Development
# Copy to .env and replace CHANGE_ME values:  cp example.env .env

# Postgres
POSTGRES_USER=vugraph
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=vugraph

# Backend / Operator Auth
OPERATOR_TOKEN=CHANGE_ME

# Centrifugo (shared between backend + centrifugo)
CENTRIFUGO_API_KEY=CHANGE_ME
CENTRIFUGO_TOKEN_SECRET=CHANGE_ME

# Centrifugo Admin UI
CENTRIFUGO_ADMIN_PASSWORD=CHANGE_ME
CENTRIFUGO_ADMIN_SECRET=CHANGE_ME
