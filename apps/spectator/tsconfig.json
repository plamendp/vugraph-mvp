{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "@vugraph/ui": ["../../packages/ui/src/index.ts"],
      "@vugraph/ui/*": ["../../packages/ui/src/*"],
      "@vugraph/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": ["src", "../../packages/ui/src", "../../packages/types/src"]
}
